# Copy this file to .env in any workspace that needs these values.
# Never commit .env files.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Spotify (PKCE — no client secret on device)
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id
EXPO_PUBLIC_SPOTIFY_REDIRECT_URI=luminary://spotify-callback

# Optional: AI for the Friend Card (post-MVP)
# ANTHROPIC_API_KEY=sk-ant-...
