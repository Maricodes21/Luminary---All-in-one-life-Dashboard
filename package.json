{
  "name": "luminary",
  "version": "0.1.0",
  "private": true,
  "description": "Luminary — Personal Growth OS. Mobile-first wellness app organized around a nightly ritual.",
  "workspaces": [
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=mobile",
    "mobile:ios": "npm run ios --workspace=mobile",
    "mobile:android": "npm run android --workspace=mobile",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "supabase:start": "cd supabase && supabase start",
    "supabase:db:reset": "cd supabase && supabase db reset",
    "mobile:android:open": "npm run android:open --workspace=mobile",
    "mobile:clear": "npm run start:clear --workspace=mobile"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "react-native-web": "^0.21.0"
  }
}
